# ==========================================================================
# Motipreca — Variables de PRODUCCIÓN (EasyPanel). PLANTILLA, no son secretos.
# Cada servicio recibe SUS variables en su panel de EasyPanel.
# Genera cada secret con: openssl rand -base64 64
# ==========================================================================

# ===== Servicio API (@motipreca/api) — variables de RUNTIME =====
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Postgres y Redis: usar el NOMBRE INTERNO del servicio en EasyPanel (no localhost).
# Ej.: si el servicio Postgres se llama "motipreca-db", el host es "motipreca-db:5432".
DATABASE_URL=postgresql://USUARIO:PASSWORD@motipreca-db:5432/motipreca?schema=public
REDIS_URL=redis://motipreca-redis:6379

# JWT — generar cada uno por separado: openssl rand -base64 64
JWT_SECRET=__GENERAR__
JWT_REFRESH_SECRET=__GENERAR__
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Dominio EXACTO del frontend, con https y SIN slash final.
CORS_ORIGIN=https://motipos.somossinergia.com

# ===== Servicio Web (@motipreca/web) =====
# VITE_API_URL va horneada como default en apps/web/Dockerfile (build time).
# NO hace falta ponerla en EasyPanel. Valor actual, solo de referencia:
VITE_API_URL=https://motiapi.somossinergia.com
VITE_APP_NAME=Motipreca
