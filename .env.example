# ==========================================================================
# Motipreca — Variables de entorno (PLANTILLA)
# Copia este archivo a .env y rellena los valores. NUNCA commitees .env.
# Genera secrets con: openssl rand -base64 64   (o -hex 16 donde se indique)
# ==========================================================================

# === BACKEND ===

# Base de datos
# Local: el Postgres de Docker se expone en el puerto 5433 del host (el 5432 lo
# usa un PostgreSQL nativo). En producción (EasyPanel) se usa el nombre del servicio.
DATABASE_URL=postgresql://motipreca:motipreca@localhost:5433/motipreca?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generar cada uno con: openssl rand -base64 64)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Servidor
PORT=3000
NODE_ENV=development        # development | production
LOG_LEVEL=info              # debug | info | warn | error

# CORS (dominio del frontend autorizado)
CORS_ORIGIN=http://localhost:5173

# === INTEGRACIONES (Fase 1.5, Semana 7+) ===

# Alegra
ALEGRA_API_URL=https://api.alegra.com/api/v1
ALEGRA_API_EMAIL=           # email de la cuenta Alegra
ALEGRA_API_TOKEN=           # NUNCA commitear

# Resend (emails)
RESEND_API_KEY=             # NUNCA commitear

# Cloudflare R2 (storage de PDFs, S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=motipreca-pdfs

# === MÓDULO DE EFECTIVO (caja interna auditable, aislado del resto) ===

# Hash de la URL privada (generar una vez con: openssl rand -hex 16)
HIDDEN_MODULE_HASH=

# === FRONTEND (Vite — se hornean en build time) ===

VITE_API_URL=http://localhost:3000
VITE_APP_NAME=Motipreca
