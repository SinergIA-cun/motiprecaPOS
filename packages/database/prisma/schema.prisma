// Motipreca — schema de Prisma.
// Nota: el schema PostgreSQL `hidden` (módulo de efectivo) se habilita junto con
// su primer modelo (Semana 4-5). Prisma rechaza un schema declarado sin tablas,
// por eso aún no se declara `schemas = ["public", "hidden"]`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

enum Rol {
  ASESOR
  CAJERO
  JEFE_DEPARTAMENTO
  GERENTE
  ADMINISTRADOR
}

/// Estado de sincronización con Alegra (Fase 1.5). Presente desde el día 1.
enum EstadoSync {
  PENDIENTE
  SINCRONIZADO
  ERROR
  DESACTUALIZADO
}

enum TipoDocumento {
  COTIZACION
  VENTA_MOSTRADOR
}

// ===========================================================================
// Modelos
// ===========================================================================

model Sucursal {
  id              String  @id @default(cuid())
  nombre          String  @unique
  prefijoFolio    String  @unique // "CUN", "PDC", "MID"
  direccion       String
  telefono        String? // pendiente de confirmar por sucursal
  email           String?
  servidorLocalIp String? // POS offline (Fase 2)
  activa          Boolean @default(true)

  // Integración Alegra (Fase 1.5) — mapea a bodega
  alegraBodegaId String?    @unique
  estadoSync     EstadoSync @default(PENDIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios     Usuario[]
  rangosFolios RangoFolio[]
  clientes     Cliente[]
  cotizaciones Cotizacion[]
  ventas       Venta[]

  @@index([activa])
}

model Usuario {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  nombre       String
  telefono     String?
  rol          Rol
  iniciales    String // para folios (ej. "RJ")
  sucursalId   String?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])

  // 2FA (TOTP) — obligatorio para Administrador
  has2FA     Boolean @default(false)
  totpSecret String?

  activo        Boolean   @default(true)
  ultimoLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cotizaciones Cotizacion[]  @relation("asesor")
  aprobaciones Aprobacion[]  @relation("aprobador")
  ventas       Venta[]       @relation("cajero")
  accesosCaja  AccesoCaja[]

  @@index([email])
  @@index([sucursalId])
}

model RangoFolio {
  id            String        @id @default(cuid())
  sucursalId    String
  sucursal      Sucursal      @relation(fields: [sucursalId], references: [id])
  tipoDocumento TipoDocumento
  rangoInicio   Int
  rangoFin      Int
  proximoFolio  Int // siguiente número disponible
  activo        Boolean       @default(true)

  @@unique([sucursalId, tipoDocumento])
  @@index([sucursalId])
}

// ===========================================================================
// CRM — Clientes
// ===========================================================================

model Cliente {
  id         String      @id @default(cuid())
  nombre     String
  tipo       TipoCliente @default(INDIVIDUAL)
  telefono   String?
  email      String?
  rfc        String? // dato fiscal básico (MVP); facturación completa en fase posterior
  notas      String?
  sucursalId String?
  sucursal   Sucursal?   @relation(fields: [sucursalId], references: [id])
  activo     Boolean     @default(true)

  // Integración Alegra (Fase 1.5)
  alegraId   String?    @unique
  estadoSync EstadoSync @default(PENDIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cotizaciones Cotizacion[]
  ventas       Venta[]

  @@index([sucursalId])
  @@index([activo])
}

enum TipoCliente {
  INDIVIDUAL
  EMPRESA
}

// ===========================================================================
// Catálogo — Productos
// (MVP: `categoria` libre + `precioBase` único. Familias y listas de precios
//  formales se incorporan en una fase posterior.)
// ===========================================================================

model Producto {
  id           String       @id @default(cuid())
  codigo       String       @unique
  nombre       String
  descripcion  String?
  categoria    String? // agrupación ligera (MVP)
  unidad       Unidad       @default(PZA)
  tipoProducto TipoProducto @default(BAJO_PEDIDO)
  precioBase   Decimal      @default(0) @db.Decimal(12, 2)
  activo       Boolean      @default(true)

  // Integración Alegra (Fase 1.5)
  alegraId   String?    @unique
  estadoSync EstadoSync @default(PENDIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      ItemCotizacion[]
  itemsVenta ItemVenta[]

  @@index([codigo])
  @@index([activo])
}

enum Unidad {
  M2
  PZA
  ML
  KG
  JGO
  LT
  M3
  TON
}

enum TipoProducto {
  BAJO_PEDIDO
  STOCK_SIN_REPOSICION
  STOCK_MINIMO
}

// ===========================================================================
// Cotizaciones
// ===========================================================================

model Cotizacion {
  id    String @id @default(cuid())
  folio String @unique // "CUN-COT-000001"

  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  asesorId   String
  asesor     Usuario  @relation("asesor", fields: [asesorId], references: [id])
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  estado EstadoCotizacion @default(ABIERTA)

  subtotal       Decimal @default(0) @db.Decimal(12, 2)
  descuentoTotal Decimal @default(0) @db.Decimal(12, 2)
  iva            Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @default(0) @db.Decimal(12, 2)

  // Aprobación (Fase 1: 1 nivel admin + reglas OR configurables)
  requiereAprobacion Boolean @default(false)
  motivoAprobacion   String? // "descuento", "monto", "descuento y monto"

  vigencia      Int      @default(15) // días
  vigenciaHasta DateTime
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        ItemCotizacion[]
  aprobaciones Aprobacion[]
  historial    HistorialCotizacion[]
  venta        Venta?

  @@index([sucursalId])
  @@index([asesorId])
  @@index([clienteId])
  @@index([estado])
  @@index([folio])
}

enum EstadoCotizacion {
  ABIERTA
  PENDIENTE_APROBACION_INTERNA
  APROBADA
  RECHAZADA_INTERNA
  RECHAZADA
  COBRADA
  EXPIRADA
  ELIMINADA
}

enum Decision {
  APROBAR
  RECHAZAR
}

model ItemCotizacion {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId   String
  producto     Producto   @relation(fields: [productoId], references: [id])

  descripcion    String // snapshot del nombre del producto al momento
  cantidad       Decimal @db.Decimal(10, 2)
  precioUnitario Decimal @db.Decimal(12, 2)
  descuentoPct   Decimal @default(0) @db.Decimal(5, 2)
  importe        Decimal @db.Decimal(12, 2)
  orden          Int     @default(0)

  @@index([cotizacionId])
}

// ===========================================================================
// Aprobaciones (Fase 1: 1 nivel = Administrador, reglas OR configurables)
// ===========================================================================

/// Reglas de aprobación configurables por el Administrador. Fase 1 usa un solo
/// nivel (nivel 1 = Administrador); los niveles 2-3 escalonados llegan en Fase 2.
model NivelAprobacion {
  id           String @id @default(cuid())
  nivel        Int    @unique // 1, 2, 3
  nombre       String // "Administrador", "Gerente", "Jefe"
  rolAprobador Rol

  // Disparadores OR: si la cotización alcanza CUALQUIERA, requiere aprobación.
  descuentoMinimo Decimal? @db.Decimal(5, 2) // % de descuento que dispara
  montoMinimo     Decimal? @db.Decimal(12, 2) // total que dispara

  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Decisión de aprobación/rechazo de una cotización (auditoría de quién decidió).
model Aprobacion {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  nivel        Int        @default(1)
  aprobadorId  String
  aprobador    Usuario    @relation("aprobador", fields: [aprobadorId], references: [id])
  decision     Decision
  motivo       String?
  createdAt    DateTime   @default(now())

  @@index([cotizacionId])
}

/// Bitácora de cambios de estado de una cotización (auditoría).
model HistorialCotizacion {
  id             String            @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion        @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  usuarioId      String? // id del usuario que provocó el cambio (sin FK, es bitácora)
  estadoAnterior EstadoCotizacion?
  estadoNuevo    EstadoCotizacion
  comentario     String?
  createdAt      DateTime          @default(now())

  @@index([cotizacionId])
  @@index([createdAt])
}

// ===========================================================================
// POS — Ventas de mostrador (Fase 1: online, cobro básico, ticket)
// ===========================================================================

model Venta {
  id    String @id @default(cuid())
  folio String @unique // "CUN-VTA-000001"

  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  cajeroId   String
  cajero     Usuario  @relation("cajero", fields: [cajeroId], references: [id])
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])

  // Si la venta proviene de una cotización (conversión). En POS directo: null.
  cotizacionId String?     @unique
  cotizacion   Cotizacion? @relation(fields: [cotizacionId], references: [id])

  subtotal       Decimal @default(0) @db.Decimal(12, 2)
  descuentoTotal Decimal @default(0) @db.Decimal(12, 2)
  iva            Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @default(0) @db.Decimal(12, 2)

  esFacturada Boolean @default(false)
  esStandby   Boolean @default(false) // efectivo sin factura (módulo hidden, fase posterior)

  createdAt DateTime @default(now())

  items ItemVenta[]
  pagos Pago[]

  @@index([sucursalId])
  @@index([cajeroId])
  @@index([createdAt])
}

model ItemVenta {
  id         String   @id @default(cuid())
  ventaId    String
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])

  descripcion    String // snapshot del nombre al momento
  cantidad       Decimal @db.Decimal(10, 2)
  precioUnitario Decimal @db.Decimal(12, 2)
  descuentoPct   Decimal @default(0) @db.Decimal(5, 2)
  importe        Decimal @db.Decimal(12, 2)
  orden          Int     @default(0)

  @@index([ventaId])
}

model Pago {
  id         String     @id @default(cuid())
  ventaId    String
  venta      Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  monto      Decimal    @db.Decimal(12, 2)
  metodoPago MetodoPago
  referencia String? // últimos 4 de tarjeta, folio de transferencia, etc.
  createdAt  DateTime   @default(now())

  @@index([ventaId])
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA_DEBITO
  TARJETA_CREDITO
  MIXTO
}

// ===========================================================================
// Caja en efectivo (auditable)
// Registro interno del efectivo cobrado sin factura, por sucursal. NO es un
// mecanismo de ocultamiento: vive en el schema público, se accede desde el
// panel de Administración (403 honesto si no eres admin) y cada consulta queda
// registrada aquí. Diseñado para sobrevivir una auditoría, no para evadirla.
// ===========================================================================

/// Bitácora de accesos a la sección de caja en efectivo (quién, cuándo, IP).
model AccesoCaja {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  ip        String?
  ruta      String // qué se consultó (ej. "resumen", "movimientos")
  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@index([createdAt])
}
